{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "memoryapp",
  "main": "src/worker/index.ts",
  "compatibility_date": "2025-06-01",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "memory-db",
      "database_id": "bb82e22b-e71f-4eef-9116-88d28b219349",
      "migrations_dir": "migrations"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "triggers": {
    // Layer-1 punctual push scan (§11.4): deterministic, every 5 minutes.
    "crons": ["*/5 * * * *"]
  },
  "vars": {
    // Model routing (§12): capture → cheap/fast tier, Brain → top tier.
    "CAPTURE_MODEL": "claude-haiku-4-5-20251001",
    "BRAIN_MODEL": "claude-opus-4-8"
  }
  // Secrets (set with `wrangler secret put <NAME>`):
  //   ANTHROPIC_API_KEY  — enables real Smart Capture + Brain (heuristic fallback without it)
  //   VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY / VAPID_SUBJECT — enables Web Push (§11)
}
