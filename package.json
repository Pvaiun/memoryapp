{
  "name": "memory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:app && wrangler dev",
    "dev:app": "vite",
    "build": "npm run build:app",
    "build:app": "vite build",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply memory-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply memory-db --remote",
    "deploy": "npm run build:app && wrangler deploy"
  },
  "dependencies": {
    "chrono-node": "^2.7.7",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.90.0"
  }
}
